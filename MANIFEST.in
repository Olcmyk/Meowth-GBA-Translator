# Binary files are downloaded at runtime from GitHub releases
# They are not included in the PyPI package to keep size small
# exclude src/meowth/binaries/windows/MeowthBridge.exe
# exclude src/meowth/binaries/macos/MeowthBridge
# exclude src/meowth/binaries/linux/MeowthBridge
recursive-exclude src/meowth/binaries *

# Include documentation
include README.md
include LICENSE

# Include configuration examples
include meowth.toml.example

# Exclude development files
exclude .gitignore
exclude .github/*
recursive-exclude tests *
recursive-exclude work *
recursive-exclude outputs *
