src/meowth/binaries/windows/MeowthBridge.exe
src/meowth/binaries/macos/MeowthBridge
src/meowth/binaries/linux/MeowthBridge

# Temporary / working files
hma_workdir/
*.json
!pyproject.toml

# Serena
.serena/

